{
  "name": "@digifemmes/mobile",
  "version": "0.1.0",
  "description": "React Native components for DigiFemmes Design System",
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "lint": "eslint src/",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@digifemmes/tokens": "workspace:*"
  },
  "devDependencies": {
    "@digifemmes/tsconfig": "workspace:*",
    "tsup": "^8.3.0",
    "vitest": "^2.1.0"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-native": ">=0.76.0"
  }
}
