{
  "name": "@digifemmes/cli",
  "version": "0.1.0",
  "description": "CLI tool for scaffolding DigiFemmes components and projects",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "digifemmes": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup src/index.ts --format cjs --dts --watch --target node18",
    "lint": "eslint src/",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@digifemmes/tokens": "workspace:*"
  },
  "devDependencies": {
    "@digifemmes/tsconfig": "workspace:*",
    "@types/node": "^20.0.0",
    "tsup": "^8.3.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
