{
  "name": "@digifemmes/cli",
  "version": "0.1.0",
  "description": "CLI tool for DigiFemmes visual generation",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": "./dist/index.js",
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format cjs --dts",
    "dev": "tsup src/index.ts --format cjs --dts --watch",
    "lint": "eslint src/",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@digifemmes/tokens": "workspace:*"
  },
  "devDependencies": {
    "@digifemmes/tsconfig": "workspace:*",
    "tsup": "^8.3.0",
    "vitest": "^2.1.0"
  }
}
