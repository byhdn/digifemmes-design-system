{
  "name": "@digifemmes/ai",
  "version": "0.1.0",
  "description": "AI chat UI and brand voice for DigiFemmes",
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --external react --external react-dom --external @digifemmes/tokens --external @digifemmes/ui",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch --external react --external react-dom --external @digifemmes/tokens --external @digifemmes/ui",
    "lint": "eslint src/",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@digifemmes/tokens": "workspace:*",
    "@digifemmes/ui": "workspace:*"
  },
  "devDependencies": {
    "@digifemmes/tsconfig": "workspace:*",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.3.0",
    "vitest": "^2.1.0"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  }
}
