{
  "name": "@digifemmes/icons",
  "version": "0.1.0",
  "description": "Icon library for DigiFemmes Design System",
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "lint": "eslint src/",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@digifemmes/tsconfig": "workspace:*",
    "@types/react": "^19.0.0",
    "tsup": "^8.3.0",
    "vitest": "^2.1.0"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  }
}
